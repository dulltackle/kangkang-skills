{
  "$comment": "Changelog content contract. One sentence per change, verb-led, user-facing language, no internal jargon. Breaking changes always first, with a migration path. 4-8 entries per version; a version with fewer than 4 entries shares a page with the prior version.",
  "type": "object",
  "required": ["product", "versions"],
  "properties": {
    "product": { "type": "string", "minLength": 1, "maxLength": 60 },
    "versions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["version", "date"],
        "properties": {
          "version": { "type": "string", "minLength": 1, "maxLength": 30 },
          "date": { "type": "string", "minLength": 4, "maxLength": 30 },
          "breaking": {
            "$comment": "Each entry names the change and the migration path.",
            "type": "array",
            "maxItems": 4,
            "items": {
              "type": "object",
              "required": ["change", "migration"],
              "properties": {
                "change": { "type": "string", "minLength": 6, "maxLength": 200 },
                "migration": { "type": "string", "minLength": 6, "maxLength": 200 }
              }
            }
          },
          "features": {
            "type": "array",
            "maxItems": 8,
            "items": { "type": "string", "minLength": 6, "maxLength": 200 }
          },
          "fixes": {
            "type": "array",
            "maxItems": 8,
            "items": { "type": "string", "minLength": 6, "maxLength": 200 }
          }
        }
      }
    }
  }
}
