{
  "$comment": "Equity report content contract. Lead with the variant perception (what you see that the market does not) and tie every thesis driver to a measurable financial impact. Professional register: 'we estimate', never hype.",
  "type": "object",
  "required": ["company", "rating", "thesis", "valuation", "catalysts", "risks"],
  "properties": {
    "company": { "type": "string", "minLength": 1, "maxLength": 60 },
    "ticker": { "type": "string", "maxLength": 16 },
    "rating": { "type": "string", "minLength": 2, "maxLength": 20 },
    "price_target": { "type": "string", "maxLength": 30 },
    "thesis": {
      "$comment": "3-5 drivers on page 1 above the fold, each backed by a number or source.",
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": { "type": "string", "minLength": 20, "maxLength": 260 }
    },
    "valuation": {
      "$comment": "At least two methods with sensitivity ranges. Single-method valuation is amateur.",
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["method", "result", "sensitivity"],
        "properties": {
          "method": { "type": "string", "minLength": 2, "maxLength": 60 },
          "result": { "type": "string", "minLength": 2, "maxLength": 120 },
          "sensitivity": { "type": "string", "minLength": 4, "maxLength": 200 }
        }
      }
    },
    "catalysts": {
      "$comment": "Each catalyst has a date and expected magnitude.",
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["event", "date", "magnitude"],
        "properties": {
          "event": { "type": "string", "minLength": 4, "maxLength": 160 },
          "date": { "type": "string", "minLength": 4, "maxLength": 30 },
          "magnitude": { "type": "string", "minLength": 2, "maxLength": 120 }
        }
      }
    },
    "risks": {
      "$comment": "Quantified and connected to the model, not generic disclaimers. Acknowledge counter-arguments before dismissing them.",
      "type": "array",
      "minItems": 2,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["risk", "impact"],
        "properties": {
          "risk": { "type": "string", "minLength": 6, "maxLength": 200 },
          "impact": { "type": "string", "minLength": 4, "maxLength": 200 }
        }
      }
    },
    "financials": {
      "$comment": "Optional table rows. Separate GAAP from non-GAAP; flag one-time items.",
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": ["label", "values"],
        "properties": {
          "label": { "type": "string", "minLength": 1, "maxLength": 60 },
          "values": {
            "type": "array",
            "minItems": 1,
            "maxItems": 6,
            "items": { "type": "string", "minLength": 1, "maxLength": 30 }
          }
        }
      }
    }
  }
}
