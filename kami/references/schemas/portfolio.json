{
  "$comment": "Portfolio content contract. Open every case study with the problem and its stakes, not with your role. 3-5 deep case studies beat 12 shallow ones. Every outcome quantifiable.",
  "type": "object",
  "required": ["name", "positioning", "contact", "about", "projects"],
  "properties": {
    "name": { "type": "string", "minLength": 1, "maxLength": 40 },
    "positioning": {
      "$comment": "One-line positioning on the cover.",
      "type": "string",
      "minLength": 6,
      "maxLength": 100
    },
    "contact": { "type": "string", "minLength": 4, "maxLength": 160 },
    "about": { "type": "string", "minLength": 60 },
    "projects": {
      "$comment": "Each project: problem and stakes first, exact role and scope, 2-3 decision points with tradeoffs, three-layer outcomes (metric + qualitative evidence + business context).",
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["title", "kind", "period", "description", "role", "challenge", "outcomes"],
        "properties": {
          "title": { "type": "string", "minLength": 2, "maxLength": 60 },
          "kind": { "type": "string", "minLength": 2, "maxLength": 30 },
          "period": { "type": "string", "minLength": 2, "maxLength": 30 },
          "description": { "type": "string", "minLength": 10, "maxLength": 160 },
          "role": { "type": "string", "minLength": 4, "maxLength": 160 },
          "challenge": { "type": "string", "minLength": 20 },
          "outcomes": {
            "type": "array",
            "minItems": 3,
            "maxItems": 5,
            "items": { "type": "string", "minLength": 10, "maxLength": 220 }
          },
          "images": {
            "$comment": "Real screenshots or photos. Missing images stay marked as gaps, never replaced with unrelated imagery.",
            "type": "array",
            "maxItems": 3,
            "items": { "type": "string", "minLength": 2, "maxLength": 200 }
          }
        }
      }
    },
    "more_works": {
      "type": "array",
      "maxItems": 8,
      "items": { "type": "string", "minLength": 4, "maxLength": 160 }
    }
  }
}
